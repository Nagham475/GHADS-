<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.ghads.controller.ChangePasswordController"
            styleClass="main-root"
            stylesheets="@../../css/style.css">

    <top>
        <MenuBar styleClass="menu-bar">
            <Menu text="File"><MenuItem text="Exit" onAction="#onMenuExit"/></Menu>
            <Menu text="Format">
                <MenuItem text="Light Theme" onAction="#onLightTheme"/>
                <MenuItem text="Dark Theme"  onAction="#onDarkTheme"/>
            </Menu>
            <Menu text="Help"><MenuItem text="About App" onAction="#onAboutApp"/></Menu>
        </MenuBar>
    </top>

    <center>
        <StackPane alignment="CENTER">
            <VBox spacing="20" maxWidth="440" styleClass="form-card">
                <padding><Insets top="36" right="40" bottom="36" left="40"/></padding>

                <VBox spacing="6">
                    <Label text="🔑 Change Password" styleClass="page-title"/>
                    <Label text="Enter your current password and a new password below."
                           styleClass="form-hint" wrapText="true"/>
                </VBox>

                <Separator/>

                <VBox spacing="14">
                    <VBox spacing="5">
                        <Label text="Current Password *" styleClass="form-label"/>
                        <PasswordField fx:id="txfCurrentPassword"
                                       promptText="Your current password"
                                       styleClass="form-field"/>
                    </VBox>
                    <VBox spacing="5">
                        <Label text="New Password * (minimum 8 characters)" styleClass="form-label"/>
                        <PasswordField fx:id="txfNewPassword"
                                       promptText="At least 8 characters"
                                       styleClass="form-field"/>
                    </VBox>
                    <VBox spacing="5">
                        <Label text="Confirm New Password *" styleClass="form-label"/>
                        <PasswordField fx:id="txfConfirmPassword"
                                       promptText="Repeat new password"
                                       styleClass="form-field"/>
                    </VBox>
                </VBox>

                <HBox spacing="12">
                    <Button text="🔑 Change Password" onAction="#onChangePassword"
                            styleClass="btn-primary" defaultButton="true"/>
                    <Button text="↺ Clear"  onAction="#onClear"  styleClass="btn-ghost"/>
                    <Button text="← Back"   onAction="#onBack"   styleClass="btn-ghost"/>
                </HBox>

            </VBox>
        </StackPane>
    </center>

</BorderPane>
